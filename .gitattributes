# Force LF line endings for source / config / scripts — Docker and Go on Linux
# choke on CRLF, and YAML/Shell weirdness is the worst kind of weirdness.
*       text=auto eol=lf

*.go    text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
Dockerfile       text eol=lf
.gitignore       text eol=lf
.dockerignore    text eol=lf
.gitattributes   text eol=lf

# Mark binary explicitly
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
